{
    "name": "9raxdev/mysql-schema-sync",
    "description": "MySQL Schema Sync GUI Tool - PHP Edition",
    "type": "project",
    "bin": ["bin/mysql-schema-sync.php"],
    "require": {
        "php": ">=8.5",
        "ext-pdo": "*",
        "ext-openssl": "*",
        "ext-ffi": "*",
        "helgesverre/libui": "dev-main",
        "9raxdev/mysql-struct-sync": "^1.0",
        "yangweijie/ui2": "^1.0",
        "nunomaduro/collision": "^8.9",
        "yangweijie/think-orm-async": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MySqlSchemaSync\\": "src/"
        },
        "classmap": [
            "vendor/yangweijie/think-orm-async/src/think/"
        ]
    }
}
